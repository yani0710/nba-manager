generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Team {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  shortName  String   @unique
  city       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  conference String?
  division   String?
  primaryColor   String?
  secondaryColor String?
  logoKey        String?
  logoPath   String?
  form       Int      @default(50)
  morale     Int      @default(50)
  nbaTeamId  Int?     @unique
  awayGames  Game[]   @relation("awayGames")
  homeGames  Game[]   @relation("homeGames")
  contracts  Contract[]
  players    Player[]
  saves      Save[]
  managedSaves Save[] @relation("managedSaves")
  transferOffersSent     TransferOffer[] @relation("TransferOffersFromTeam")
  transferOffersReceived TransferOffer[] @relation("TransferOffersToTeam")
  transferTransactionsSent TransferTransactionLog[] @relation("TransferTxnFromTeam")
  transferTransactionsReceived TransferTransactionLog[] @relation("TransferTxnToTeam")
  contractOffers ContractOffer[]
  tradeProposalsSent TradeProposal[] @relation("TradeProposalsFromTeam")
  tradeProposalsReceived TradeProposal[] @relation("TradeProposalsToTeam")
  capSnapshots TeamCapSnapshot[]
  transactionHistory TransactionHistory[]
  weeklyStandingsSnapshots WeeklyStandingsSnapshot[]
  monthlyTeamMetricsSnapshots MonthlyTeamMetricsSnapshot[]
}

model Player {
  id          Int        @id @default(autoincrement())
  name        String
  externalRef String?    @unique
  number      Int?
  jerseyNumber Int?
  jerseyCode  String?
  position    String
  salary      Int?
  teamId      Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  firstName   String?
  birthDate   DateTime?
  age         Int?
  debutYear   Int?
  finalYear   Int?
  school      String?
  hallOfFame  Boolean?
  heightCm    Int?
  weightKg    Int?
  nationality String?
  bioSource   String?
  gamesCareer Int?
  ptsCareer   Float?
  trbCareer   Float?
  astCareer   Float?
  fgPct       Float?
  fg3Pct      Float?
  ftPct       Float?
  efgPct      Float?
  per         Float?
  ws          Float?
  active      Boolean    @default(false)
  offensiveRating Int    @default(60)
  overallBase Int        @default(60)
  overall     Int        @default(60)
  overallCurrent Int     @default(60)
  defensiveRating Int    @default(60)
  physicalRating Int     @default(60)
  iqRating    Int        @default(60)
  form        Int        @default(60)
  morale      Int        @default(65)
  fatigue     Int        @default(10)
  formTrendDays Int      @default(0)
  lastFormSnapshot Int   @default(70)
  potential   Int        @default(75)
  handedness  String?
  primaryPosition   String     @default("N/A")
  secondaryPosition String?
  attributes  Json?
  isActive    Boolean    @default(true)
  lastName    String?
  nbaPlayerId Int?       @unique
  contracts   Contract?
  gameStats   GameStat[]
  seasonAdvanced PlayerSeasonAdvanced[]
  seasonImpact   PlayerSeasonImpact[]
  trainingPlans  PlayerTrainingPlan[]
  contractProposals PlayerContractProposal[]
  transferOfferPieces TransferOfferPlayerPiece[]
  gameLogs    PlayerGameLog[]
  team        Team       @relation(fields: [teamId], references: [id])
  contractOffers ContractOffer[]
  tradeProposalItems TradeProposalItem[]

  @@unique([teamId, jerseyCode], map: "team_jersey_code_unique")
}

model PlayerSeasonImpact {
  id          Int      @id @default(autoincrement())
  playerId    Int
  season      Int
  teamCode    String
  mpg         Float?
  minTotal    Float?
  onBallPct   Float?
  dpm         Float?
  odpm        Float?
  ddpm        Float?
  pts         Float?
  ptsCreated  Float?
  ast         Float?
  rimAst      Float?
  reb         Float?
  ts          Float?
  rts         Float?
  tov         Float?
  ctovPct     Float?
  twoPpct     Float?
  threePpct   Float?
  threePA     Float?
  ftPct       Float?
  fta         Float?
  oreb        Float?
  dreb        Float?
  stl         Float?
  blk         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, season])
  @@index([season, teamCode])
}

model Contract {
  id                 Int            @id @default(autoincrement())
  playerId           Int            @unique
  teamId             Int?
  salary             Int?
  startYear          Int?
  endYear            Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  averageAnnualValue Int?
  contractType       String?
  type               String?
  optionType         String?
  isTwoWay           Boolean        @default(false)
  currentYearSalary  Int?
  guaranteedValue    BigInt?
  totalValue         BigInt?
  player             Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team               Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  contractYears      ContractYear[]
}

model ContractYear {
  id         Int      @id @default(autoincrement())
  contractId Int
  season     String
  salary     Int
  guaranteed Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, season])
}

model Game {
  id         Int        @id @default(autoincrement())
  saveId     Int?
  homeTeamId Int
  awayTeamId Int
  homeScore  Int        @default(0)
  awayScore  Int        @default(0)
  gameDate   DateTime
  status     String     @default("scheduled")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  awayTeam   Team       @relation("awayGames", fields: [awayTeamId], references: [id])
  homeTeam   Team       @relation("homeGames", fields: [homeTeamId], references: [id])
  save       Save?      @relation(fields: [saveId], references: [id], onDelete: Cascade)
  gameStats  GameStat[]

  @@index([saveId, status, gameDate])
}

model GameStat {
  id        Int      @id @default(autoincrement())
  gameId    Int
  playerId  Int
  teamId    Int?
  minutes   Int      @default(0)
  points    Int      @default(0)
  twoPtMade Int      @default(0)
  twoPtAtt  Int      @default(0)
  threePtMade Int    @default(0)
  threePtAtt  Int    @default(0)
  ftMade    Int      @default(0)
  ftAtt     Int      @default(0)
  dunks     Int      @default(0)
  oreb      Int      @default(0)
  dreb      Int      @default(0)
  rebounds  Int      @default(0)
  assists   Int      @default(0)
  steals    Int      @default(0)
  blocks    Int      @default(0)
  turnovers Int      @default(0)
  fouls     Int      @default(0)
  plusMinus Int      @default(0)
  performanceRating Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([gameId, teamId, playerId])
}

model Save {
  id             Int            @id @default(autoincrement())
  name           String
  description    String?
  data           Json
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  coachProfileId Int?
  currentDate    DateTime       @default(now())
  season         String         @default("2025-26")
  teamId         Int?
  managedTeamId  Int?
  coachName      String?
  coachAvatarId  String?
  userId         Int?
  version        Int            @default(1)
  games          Game[]
  inboxMessages  InboxMessage[]
  playerTrainingPlans PlayerTrainingPlan[]
  teamTrainingDayPlans TeamTrainingDayPlan[]
  transferOffers TransferOffer[]
  transferTransactionLogs TransferTransactionLog[]
  contractOffers ContractOffer[]
  tradeProposals TradeProposal[]
  negotiationEvents NegotiationEvent[]
  transactionHistory TransactionHistory[]
  capSnapshots TeamCapSnapshot[]
  ownerGoals     OwnerGoal[]
  jobSecurityEvents JobSecurityEvent[]
  managerCareerStats ManagerCareerStat[]
  managerAwards  ManagerAward[]
  boardReviews   BoardReview[]
  weeklyStandingsSnapshots WeeklyStandingsSnapshot[]
  monthlyTeamMetricsSnapshots MonthlyTeamMetricsSnapshot[]
  coachProfile   CoachProfile?  @relation(fields: [coachProfileId], references: [id])
  team           Team?          @relation(fields: [teamId], references: [id])
  managedTeam    Team?          @relation("managedSaves", fields: [managedTeamId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])
}

model OwnerGoal {
  id           Int      @id @default(autoincrement())
  saveId       Int
  season       String
  type         String
  title        String
  description  String
  targetNumber Float?
  targetText   String?
  currentValue Float?   @default(0)
  progress     Float?   @default(0)
  weight       Float?   @default(0.25)
  status       String   @default("on_track")
  meta         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  save         Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@unique([saveId, season, type])
  @@index([saveId, season, status])
}

model JobSecurityEvent {
  id        Int      @id @default(autoincrement())
  saveId     Int
  date       DateTime
  score      Int
  delta      Int
  reason     String
  source     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  save       Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@index([saveId, date])
  @@index([saveId, source, createdAt])
}

model ManagerCareerStat {
  id                 Int      @id @default(autoincrement())
  saveId             Int
  season             String
  yearsManaged       Int      @default(1)
  wins               Int      @default(0)
  losses             Int      @default(0)
  playoffAppearances Int      @default(0)
  championships      Int      @default(0)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  save               Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@unique([saveId, season])
  @@index([saveId, season, createdAt])
}

model ManagerAward {
  id          Int      @id @default(autoincrement())
  saveId       Int
  season       String
  awardType    String
  title        String
  description  String?
  awardedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  save         Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@index([saveId, season, awardedAt])
  @@unique([saveId, season, awardType, title])
}

model BoardReview {
  id        Int      @id @default(autoincrement())
  saveId     Int
  season     String
  week       Int?
  date       DateTime
  title      String
  verdict    String
  summary    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  save       Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@index([saveId, season, date])
}

model WeeklyStandingsSnapshot {
  id        Int      @id @default(autoincrement())
  saveId     Int
  season     String
  week       Int
  conference String
  teamId     Int
  rank       Int
  wins       Int
  losses     Int
  pct        Float
  gb         Float
  streak     String
  l10        String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  save       Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([saveId, season, week, teamId])
  @@index([saveId, week, conference])
}

model MonthlyTeamMetricsSnapshot {
  id             Int      @id @default(autoincrement())
  saveId          Int
  season          String
  monthKey        String
  teamId          Int
  payroll         Int
  avgMorale       Float
  offenseRating   Float
  defenseRating   Float
  form            Float
  wins            Int
  losses          Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  save            Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([saveId, season, monthKey, teamId])
  @@index([saveId, season, monthKey])
}

model ContractOffer {
  id               Int      @id @default(autoincrement())
  saveId           Int
  teamId           Int
  playerId         Int
  salaryPerYear    Int
  years            Int
  rolePromise      String
  optionType       String? // TEAM_OPTION | PLAYER_OPTION | NONE
  status           String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN | EXPIRED
  submittedDay     Int
  decisionDay      Int
  expiresDay       Int?
  expectedSalary   Int?
  interestScore    Float?
  decisionReason   String?
  capSummary       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  resolvedAt       DateTime?
  save             Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([saveId, status, decisionDay])
  @@index([saveId, teamId, createdAt])
}

model TradeProposal {
  id               Int      @id @default(autoincrement())
  saveId           Int
  fromTeamId       Int
  toTeamId         Int
  status           String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | COUNTERED | WITHDRAWN | EXPIRED | ILLEGAL
  submittedDay     Int
  decisionDay      Int
  expiresDay       Int?
  cashOut          Int      @default(0)
  cashIn           Int      @default(0)
  aiScore          Float?
  decisionReason   String?
  validation       Json?
  counterPayload   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  resolvedAt       DateTime?
  save             Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  fromTeam         Team     @relation("TradeProposalsFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam           Team     @relation("TradeProposalsToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)
  items            TradeProposalItem[]

  @@index([saveId, status, decisionDay])
  @@index([saveId, submittedDay])
}

model TradeProposalItem {
  id              Int      @id @default(autoincrement())
  proposalId      Int
  itemType        String   @default("PLAYER") // PLAYER | PICK | CASH
  direction       String   // OUT | IN (from manager perspective)
  playerId        Int?
  pickYear        Int?
  pickRound       Int?
  cashAmount      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  proposal        TradeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  player          Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([proposalId, direction])
  @@index([playerId])
}

model NegotiationEvent {
  id              Int      @id @default(autoincrement())
  saveId          Int
  entityType      String   // CONTRACT_OFFER | TRADE_PROPOSAL
  entityId        Int
  eventType       String   // SUBMITTED | COUNTERED | ACCEPTED | REJECTED | EXPIRED | WITHDRAWN
  actor           String   // USER | AI_TEAM | PLAYER_AGENT | SYSTEM
  day             Int
  title           String
  body            String?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  save            Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@index([saveId, day, createdAt])
  @@index([entityType, entityId])
}

model TransactionHistory {
  id              Int      @id @default(autoincrement())
  saveId          Int
  teamId          Int?
  category        String   // FREE_AGENCY | TRADE | WAIVER | CONTRACT
  status          String   // COMPLETED | FAILED | REJECTED | EXPIRED
  referenceType   String   // CONTRACT_OFFER | TRADE_PROPOSAL | TRANSFER_OFFER
  referenceId     Int
  day             Int
  title           String
  body            String?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  save            Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([saveId, day, createdAt])
  @@index([referenceType, referenceId])
}

model TeamCapSnapshot {
  id              Int      @id @default(autoincrement())
  saveId          Int
  teamId          Int
  day             Int
  payroll         Int
  capSpace        Int
  luxuryTax       Int
  overCap         Boolean  @default(false)
  overTax         Boolean  @default(false)
  hardCap         Int?
  apron           Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  save            Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([saveId, day])
  @@unique([saveId, teamId, day])
}

model PlayerTrainingPlan {
  id        String   @id @default(cuid())
  saveId     Int
  playerId   Int
  focus      String
  intensity  String
  dayPlan    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  save       Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([saveId, playerId])
}

model TeamTrainingDayPlan {
  id              String   @id @default(cuid())
  saveId          Int
  dayOfWeek       String
  intensity       String
  focus           String
  durationMinutes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  save            Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@unique([saveId, dayOfWeek])
  @@index([saveId])
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  coachProfiles CoachProfile[]
  saves         Save[]
}

model CoachProfile {
  id             Int      @id @default(autoincrement())
  userId         Int?
  displayName    String
  avatarId       String
  reputation     Int      @default(50)
  preferredStyle String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id])
  saves          Save[]
}

model InboxMessage {
  id        Int      @id @default(autoincrement())
  saveId    Int
  date      DateTime
  type      String
  title     String
  body      String
  fromName  String
  relatedOfferId Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  save      Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  transferOffer TransferOffer? @relation(fields: [relatedOfferId], references: [id], onDelete: SetNull)

  @@index([saveId, date])
  @@index([saveId, createdAt, isRead])
  @@index([relatedOfferId])
}

model TransferOffer {
  id               Int      @id @default(autoincrement())
  saveId           Int
  fromTeamId       Int
  toTeamId         Int
  outgoingPlayerIds Int[]   @default([])
  incomingPlayerIds Int[]   @default([])
  cashOut          Int      @default(0)
  cashIn           Int      @default(0)
  sellOnPct        Int?
  status           String   @default("DRAFT")
  createdDay       Int
  resolveDay       Int
  aiReason         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  resolvedAt       DateTime?
  save             Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  fromTeam         Team     @relation("TransferOffersFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam           Team     @relation("TransferOffersToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)
  inboxMessages    InboxMessage[]
  contractProposals PlayerContractProposal[]
  playerPieces      TransferOfferPlayerPiece[]
  transactionLogs   TransferTransactionLog[]

  @@index([saveId, status, resolveDay])
  @@index([saveId, createdDay])
}

model PlayerContractProposal {
  id                   Int      @id @default(autoincrement())
  offerId              Int
  playerId             Int
  proposedSalary       Int
  years                Int
  role                 String
  responseDeadlineDay  Int
  status               String   @default("OFFERED")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  offer                TransferOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  player               Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([offerId, status])
  @@index([playerId])
}

model TransferOfferPlayerPiece {
  id        Int      @id @default(autoincrement())
  offerId    Int
  playerId   Int
  // side = who owns the piece in the offer context: FROM team or TO team
  side      String
  // direction = whether this piece is outgoing from manager team or incoming to manager team
  direction String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  offer     TransferOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([offerId, side])
  @@index([offerId, direction])
  @@unique([offerId, playerId, side, direction])
}

model TransferTransactionLog {
  id              Int      @id @default(autoincrement())
  saveId          Int
  offerId         Int
  fromTeamId      Int
  toTeamId        Int
  day             Int
  eventType       String
  status          String
  message         String?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  save            Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)
  offer           TransferOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  fromTeam        Team     @relation("TransferTxnFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeam          Team     @relation("TransferTxnToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)

  @@index([saveId, day])
  @@index([offerId, createdAt])
}

model PlayerGameLog {
  id        Int      @id @default(autoincrement())
  date      DateTime
  teamCode  String
  oppCode   String
  result    String?
  mp        Float?

  fg        Int?
  fga       Int?
  tp        Int?
  tpa       Int?
  ft        Int?
  fta       Int?

  orb       Int?
  drb       Int?
  trb       Int?
  ast       Int?
  stl       Int?
  blk       Int?
  tov       Int?
  pf        Int?
  pts       Int?

  gmSc      Float?

  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, date, teamCode])
  @@index([date, teamCode])
}

model PlayerSeasonAdvanced {
  id          Int      @id @default(autoincrement())
  playerId    Int
  season      Int
  teamCode    String
  pos         String
  per         Float?
  tsPercent   Float?
  x3pAr       Float?
  fTr         Float?
  orbPercent  Float?
  drbPercent  Float?
  trbPercent  Float?
  astPercent  Float?
  stlPercent  Float?
  blkPercent  Float?
  tovPercent  Float?
  usgPercent  Float?
  ows         Float?
  dws         Float?
  ws          Float?
  ws48        Float?
  obpm        Float?
  dbpm        Float?
  bpm         Float?
  vorp        Float?
  minutes     Float?
  onBallPercent Float?
  dpm         Float?
  odpm        Float?
  ddpm        Float?
  pts         Float?
  ptsCreated  Float?
  ast         Float?
  rimAst      Float?
  reb         Float?
  rtsPercent  Float?
  tov         Float?
  cTovPercent Float?
  twoPointPercent Float?
  threePointPercent Float?
  threePointAttempts Float?
  ftPercent   Float?
  fta         Float?
  oreb        Float?
  dreb        Float?
  stl         Float?
  blk         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, season])
  @@index([season, teamCode])
}
